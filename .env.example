# Environment configuration for the whole stack.
#   cp .env.example .env
# Docker Compose reads this file. Every value also has a built-in default (see
# docker-compose.yml / backend/app/config.py), so the stack runs with zero configuration.

# --- PostgreSQL (the `db` service; Compose builds the backend's DATABASE_URL from these) ---
POSTGRES_USER=hixie
POSTGRES_PASSWORD=hixie
POSTGRES_DB=note_tracker
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8000
# JWT signing secret — MUST be a long random value in production.
AUTH_SECRET_KEY=dev-only-insecure-secret-change-me
# Comma-separated allowed frontend origins (match FRONTEND_PORT / your production domain).
CORS_ORIGINS=http://localhost:5173
# Running the backend WITHOUT Docker, or against an external managed Postgres? Set the
# SQLAlchemy URL directly (takes precedence; unset = local SQLite fallback):
# DATABASE_URL=postgresql://user:password@host:5432/note_tracker

# --- Frontend (Vite public build key) ---
FRONTEND_PORT=5173
# Backend URL the browser calls; baked into the production build at build time.
VITE_API_BASE=http://localhost:8000
